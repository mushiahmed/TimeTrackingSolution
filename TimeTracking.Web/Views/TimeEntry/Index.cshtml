@model TimeTracking.Core.Models.PagedResult<TimeTracking.Core.Models.TimeEntry>
@using MvcPaging

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Time Entries";
}

<link href="~/Content/css/employee.css" rel="stylesheet" />
<script src="~/Scripts/employee.js"></script>

<h2 class="page-title">Time Entries</h2>
@using (Html.BeginForm("Index", "TimeEntry", FormMethod.Get))
{
    <div class="row" style="margin-bottom:12px;">
        <div class="col-md-3">
            <label for="employeeId">Employee</label>
            @Html.DropDownList("employeeId",
                new SelectList(ViewBag.Employees ?? Enumerable.Empty<object>(), "Id", "FullName", Model.EmplyeeId),
                "All",
                new { @class = "form-control", id = "employeeId" })
        </div>
        <div class="col-md-3">
            <label for="projectId">Project</label>
            @Html.DropDownList("projectId",
                new SelectList(ViewBag.Projects ?? Enumerable.Empty<object>(), "Id", "Name", Model.ProjectId),
                "All",
                new { @class = "form-control", id = "projectId" })
        </div>
        <div class="col-md-2">
            <label for="startDate">Start Date</label>
            @Html.TextBox("startDate", Model.FromDate.Value.ToString("yyyy-MM-dd") ?? "", new { @class = "form-control", type = "date", id = "startDate" })
        </div>
        <div class="col-md-2">
            <label for="endDate">End Date</label>
            @Html.TextBox("endDate", Model.ToDate.Value.ToString("yyyy-MM-dd") ?? "", new { @class = "form-control", type = "date", id = "endDate" })
        </div>
        <div class="col-md-2" style="padding-top:24px;">
            <button type="submit" class="btn btn-primary">Search</button>
            <a href="@Url.Action("Index", "TimeEntry")" class="btn btn-default">Reset</a>
        </div>
    </div>
}

<div id="formError" class="alert alert-danger" style="display:none;"></div>

<table class="table table-employee">

    <tr>
        <th>ID</th>
        <th>Employee</th>
        <th>Project Name</th>
        <th>Date</th>
        <th>Hours</th>
        <th>Source</th>
        <th>Actions</th>
    </tr>

    @foreach (var t in Model.Items)
    {
        <tr>
            <td>@t.Id</td>
            <td>@(t.EmployeeName ?? "")</td>
            <td>@(t.ProjectName ?? t.ProjectName ?? "")</td>
            <td>@(t.EntryDate.ToString("yyyy-MM-dd"))</td>
            <td>@t.Hours</td>
            <td>@t.Source</td>
            <td>
                <a href="@Url.Action("Update", "TimeEntry", new { id = t.Id })" class="btn btn-default btn-update" title="Edit" style="width:34px;height:34px;padding:6px;text-align:center;">
                    <i class="fa fa-pencil" aria-hidden="true"></i>
                </a>
                <a href="@Url.Action("Delete", "TimeEntry", new { id = t.Id })" class="btn btn-default btn-delete" title="Delete" style="width:34px;height:34px;padding:6px;text-align:center;margin-left:6px;">
                    <i class="fa fa-trash" aria-hidden="true"></i>

                </a>
            </td>
        </tr>
    }

</table>

<div class="col-xs-12">
    <div class="paging-new" style="margin-top: 20px;">
        <div class="pager">
            @Html.Pager(Model?.PageSize ?? 10, Model?.PageNumber ?? 1, Model?.TotalRecords ?? 0, "Index", new { employeeId = Model.EmplyeeId, projectId = Model.ProjectId, startDate = Model.FromDate?.ToString("yyyy-MM-dd"), endDate = Model.ToDate?.ToString("yyyy-MM-dd") }, "Default")
        </div>
    </div>
</div>

@section Scripts{
    
    <script type="text/javascript">
        $(".btn-delete").on("click", function (e) {
            if (!confirm('Are you sure you want to delete this time entry?')) {
                e.preventDefault();
                e.stopPropagation();
            }
        });
        $(document).ready(function () {
            var isError = @(ViewBag.Error != null && !string.IsNullOrWhiteSpace(ViewBag.Error.ToString()) ? "true" : "false");

            if (isError) {
                var msg = "@ViewBag.Error";
                $('#formError').text(msg).show();
            }
        });




    </script>

}